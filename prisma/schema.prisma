generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ConversationStatus {
  open
  resolved
  escalated
  closed
}

enum MessageDirection {
  inbound
  outbound
}

enum QueryType {
  pre_sales_availability
  pre_sales_pricing
  post_sales_checkin
  special_request
  complaint
  general_enquiry
}

enum MessageAction {
  auto_send
  agent_review
  escalate
}

enum ReservationStatus {
  confirmed
  cancelled
  completed
  pending
}

enum PaymentStatus {
  pending
  paid
  refunded
  failed
}

model Guest {
  id            String           @id @default(uuid())

  fullName      String

  conversations Conversation[]

  reservations  Reservation[]

  createdAt     DateTime         @default(now())
}

model Property {
  id                      String           @id @default(uuid())

  propertyCode            String           @unique

  name                    String

  location                String

  bedrooms                Int

  maxGuests               Int

  privatePool             Boolean          @default(false)

  checkInTime             String

  checkOutTime            String

  baseRatePerNight        Decimal

  baseGuestCount          Int

  extraGuestCharge        Decimal

  wifiPassword            String?

  caretakerAvailability   String?

  chefOnCall              Boolean          @default(false)

  chefBookingRequired     Boolean          @default(false)

  cancellationPolicy      String?

  reservations            Reservation[]

  conversations           Conversation[]

  createdAt               DateTime         @default(now())
}

model Reservation {
  id                  String                @id @default(uuid())

  bookingRef          String                @unique

  guestId             String

  propertyId          String

  checkInDate         DateTime

  checkOutDate        DateTime

  numberOfGuests      Int

  totalAmount         Decimal

  paymentStatus       PaymentStatus         @default(pending)

  status              ReservationStatus     @default(confirmed)

  guest               Guest                 @relation(fields: [guestId], references: [id])

  property            Property              @relation(fields: [propertyId], references: [id])

  conversations       Conversation[]

  createdAt           DateTime              @default(now())

  updatedAt           DateTime              @updatedAt
}

model Conversation {
  id                  String                @id @default(uuid())

  guestId             String

  reservationId       String?

  propertyId          String

  source              String

  status              ConversationStatus    @default(open)

  guest               Guest                 @relation(fields: [guestId], references: [id])

  reservation         Reservation?          @relation(fields: [reservationId], references: [id])

  property            Property              @relation(fields: [propertyId], references: [id])

  messages            Message[]

  createdAt           DateTime              @default(now())

  updatedAt           DateTime              @updatedAt
}

model Message {
  id                  String                @id @default(uuid())

  conversationId      String

  direction           MessageDirection

  messageText         String

  queryType           QueryType?

  confidenceScore     Float?

  action              MessageAction?

  aiDrafted           Boolean               @default(false)

  agentEdited         Boolean               @default(false)

  autoSent            Boolean               @default(false)

  conversation        Conversation          @relation(fields: [conversationId], references: [id])

  createdAt           DateTime              @default(now())
}